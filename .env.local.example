CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=http://127.0.0.1:3210
SITE_URL=http://127.0.0.1:3211
VITE_CONVEX_SITE_URL=http://127.0.0.1:3211

# Convex Auth JWT keys do not belong in this file.
# Generate and store JWT_PRIVATE_KEY + JWKS on the Convex deployment with:
# npm run auth:setup-local

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Cloudflare RealtimeKit credentials
